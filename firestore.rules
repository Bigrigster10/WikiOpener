rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isOwner(userId) { 
      return request.auth != null && request.auth.uid == userId; 
    }
    
    // Users Collection (contains balances, net worth, cases opened)
    match /users/{userId} {
      // Anyone can read profiles to populate the leaderboard
      allow read: if true;
      // Only the authenticated user can create/update their own profile
      allow create, update: if isOwner(userId);
      
      match /inventory/{itemId} {
        // Only the authenticated user can read/write their inventory items
        allow read, create, update, delete: if isOwner(userId);
      }
    }
    
    // Legacy maps just in case
    match /gameProfiles/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
    }
    match /items/{itemId} {
      allow read, create, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // Stats collection (jackpot)
    match /stats/{statId} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }
  }
}
